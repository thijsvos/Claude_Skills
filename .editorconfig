root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.sh]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.md]
indent_size = 2
# Markdown uses two trailing spaces as a hard line break — preserve them.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
